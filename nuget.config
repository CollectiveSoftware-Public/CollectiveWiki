<?xml version="1.0" encoding="utf-8"?>
<!-- SPDX-License-Identifier: GPL-3.0-or-later -->
<!--
  Collective.* packages (Platform.Abstractions, Platform, Code.Core) are vendored in build/packages
  (a committed offline feed) so restore works without a NuGet server. The one net-new third-party dep
  (Markdig) and the test SDKs come from nuget.org. clear + explicit sources => deterministic CI restore.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="collective-local" value="build/packages" />
  </packageSources>
</configuration>
